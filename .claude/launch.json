{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend-static",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "8080"],
      "port": 8080
    },
    {
      "name": "backend-django",
      "runtimeExecutable": "python",
      "runtimeArgs": ["backend/manage.py", "runserver", "0.0.0.0:8000"],
      "port": 8000
    },
    {
      "name": "docker-full",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "--build"],
      "port": 80
    }
  ]
}
